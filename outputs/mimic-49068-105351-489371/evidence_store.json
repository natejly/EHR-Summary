    {
      "id": "E:note:row489371:1",
      "kind": "note_sentence",
      "display": "This is a 69 yoM CAD s/p CABG,DM, and decreased LVEF 20-30% on coumadin    who e",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row489371#s1",
      "text": "This is a 69 yoM CAD s/p CABG,DM, and decreased LVEF 20-30% on coumadin    who experienced right flank pain was driving his car. came to [**Hospital1 19**] ED,    found to have spontaneous RP/L kidney bleed."
    },
    {
      "id": "E:note:row489371:2",
      "kind": "note_sentence",
      "display": "Admitted to the floor for    further w/u. got 2 units FFP. while on the floor pt",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row489371#s2",
      "text": "Admitted to the floor for    further w/u. got 2 units FFP. while on the floor pt desatting,    decreased UOP despite 60mg lasix. projectile vomited CG emesis, placed    on 100% NRB and tx to the MICU."
    },
    {
      "id": "E:note:row489371:3",
      "kind": "note_sentence",
      "display": "Here he is doing better, 96-97% on 6L    n/c.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row489371#s3",
      "text": "Here he is doing better, 96-97% on 6L    n/c."
    },
