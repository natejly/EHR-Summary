    {
      "id": "E:note:row466035:1",
      "kind": "note_sentence",
      "display": "80yo Portugese speaking female S/P recent hospitalization at [**Hospital1 3633**",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s1",
      "text": "80yo Portugese speaking female S/P recent hospitalization at [**Hospital1 3633**] with    CP -> cath lab where she was found to have 3VD (including 95% LM): No    intervention and surgery declined her as she was too high risk."
    },
    {
      "id": "E:note:row466035:2",
      "kind": "note_sentence",
      "display": "She was    DC d to home and suffered a  reoccurrence of chest pain 2 days later ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s2",
      "text": "She was    DC d to home and suffered a  reoccurrence of chest pain 2 days later ->    ruled in at [**Hospital3 2794**] for STEMI ( Inferior MI)."
    },
    {
      "id": "E:note:row466035:3",
      "kind": "note_sentence",
      "display": "Peak cpk 1350.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s3",
      "text": "Peak cpk 1350."
    },
    {
      "id": "E:note:row466035:4",
      "kind": "note_sentence",
      "display": "Transferred to [**Hospital1 19**] for re-evalulation of CABG.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s4",
      "text": "Transferred to [**Hospital1 19**] for re-evalulation of CABG."
    },
    {
      "id": "E:note:row466035:5",
      "kind": "note_sentence",
      "display": "Pt admitted on    heparin and ntg, NTG weaned off [**7-29**], remains on heparin",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s5",
      "text": "Pt admitted on    heparin and ntg, NTG weaned off [**7-29**], remains on heparin."
    },
    {
      "id": "E:note:row466035:6",
      "kind": "note_sentence",
      "display": "Cardiac    Surgery came by to see pt and now have cardiac cath films from [**Hos",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s6",
      "text": "Cardiac    Surgery came by to see pt and now have cardiac cath films from [**Hospital1 3633**] as    of [**7-30**]; CSurg waiting to determine her candidacy is c/b ARF and HCV    cirrhosis."
    },
    {
      "id": "E:note:row466035:7",
      "kind": "note_sentence",
      "display": "Temp pacing wire inserted [**7-30**] for bradycardia 28-30 Afib s/p inferior    ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s7",
      "text": "Temp pacing wire inserted [**7-30**] for bradycardia 28-30 Afib s/p inferior    MI."
    },
    {
      "id": "E:note:row466035:8",
      "kind": "note_sentence",
      "display": "[**8-2**]; pacer rate increased and patent started both IV Lasix gtt and    diur",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s8",
      "text": "[**8-2**]; pacer rate increased and patent started both IV Lasix gtt and    diuril as having increasing O2 requirements (on non-rebreather) and    worsening edema."
    },
    {
      "id": "E:note:row466035:9",
      "kind": "note_sentence",
      "display": "Has experienced some confusion over past few days but cooperative w/    care.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s9",
      "text": "Has experienced some confusion over past few days but cooperative w/    care."
    },
    {
      "id": "E:note:row466035:10",
      "kind": "note_sentence",
      "display": "Alert and oriented x [**2-16**].",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row466035#s10",
      "text": "Alert and oriented x [**2-16**]."
    },
    {
      "id": "E:note:row466035:11",
