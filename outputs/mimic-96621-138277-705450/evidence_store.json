    },
    {
      "id": "E:note:row705450:2",
      "kind": "note_sentence",
      "display": "He was at    work at a construction site and fell from 4^th wrung on a ladder   ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row705450#s2",
      "text": "He was at    work at a construction site and fell from 4^th wrung on a ladder    breaking through a barrier beam and into a trench approx 14-20 feet    deep."
    },
    {
      "id": "E:note:row705450:3",
      "kind": "note_sentence",
      "display": "Pt had no LOC at the scene and was MAE s.",
      "code": null,
      "value": null,
