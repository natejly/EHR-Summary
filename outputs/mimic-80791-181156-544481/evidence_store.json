    {
      "id": "E:note:row544481:3",
      "kind": "note_sentence",
      "display": "Post op patient    extubated, complained of pain, was given morphine, developed ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row544481#s3",
      "text": "Post op patient    extubated, complained of pain, was given morphine, developed    hypotension and apnea and had to be reintubated and fluid resucitated    wih 7-8 L fluid."
    },
