    {
      "id": "E:note:row509076:1",
      "kind": "note_sentence",
      "display": "75-year-old woman with history of hypertension and multiple myeloma    presents ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s1",
      "text": "75-year-old woman with history of hypertension and multiple myeloma    presents to ICU with tachycardia to 180s this AM in setting of multiple    refractory episodes of atrial fibrillation with RVR earlier in hospital    course."
    },
    {
      "id": "E:note:row509076:2",
      "kind": "note_sentence",
      "display": "Altered mental status (not Delirium)    Assessment:    Pt with labile MS, per 7F",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s2",
      "text": "Altered mental status (not Delirium)    Assessment:    Pt with labile MS, per 7F report patient has been nonverbal for several    days due to mucosal irritation; MS has been progressively worsening, on    assessment patient sedated on fentanyl/versed."
    },
    {
      "id": "E:note:row509076:3",
      "kind": "note_sentence",
      "display": "Arousable to stimuli    with periods of increased alertness.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s3",
      "text": "Arousable to stimuli    with periods of increased alertness."
    },
    {
      "id": "E:note:row509076:4",
      "kind": "note_sentence",
      "display": "Appears uncomfortable w/mouth care    and general care.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s4",
      "text": "Appears uncomfortable w/mouth care    and general care."
    },
    {
      "id": "E:note:row509076:5",
      "kind": "note_sentence",
      "display": "Does not follow commands.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s5",
      "text": "Does not follow commands."
    },
    {
      "id": "E:note:row509076:6",
      "kind": "note_sentence",
      "display": "Action:    Reoriented frequently, requires additional boluses of fentanyl/versed",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s6",
      "text": "Action:    Reoriented frequently, requires additional boluses of fentanyl/versed    w/mouth care and/or general care."
    },
    {
      "id": "E:note:row509076:7",
      "kind": "note_sentence",
      "display": "Response:    Ongoing    Plan:    Continue to reorient frequently, wean sedation ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s7",
      "text": "Response:    Ongoing    Plan:    Continue to reorient frequently, wean sedation as tolerated."
    },
    {
      "id": "E:note:row509076:8",
      "kind": "note_sentence",
      "display": "Respiratory failure    Assessment:    Received patient intubated and vented.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s8",
      "text": "Respiratory failure    Assessment:    Received patient intubated and vented."
    },
    {
      "id": "E:note:row509076:9",
      "kind": "note_sentence",
      "display": "Patient vented on PSV 40% 14/5,    on assessment breath sounds clear diminished ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s9",
      "text": "Patient vented on PSV 40% 14/5,    on assessment breath sounds clear diminished at the bases."
    },
    {
      "id": "E:note:row509076:10",
      "kind": "note_sentence",
      "display": "Unlabored    breathing.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s10",
      "text": "Unlabored    breathing."
    },
    {
      "id": "E:note:row509076:11",
      "kind": "note_sentence",
      "display": "Thick bloody secretions suctioned orally and via ETT.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row509076#s11",
      "text": "Thick bloody secretions suctioned orally and via ETT."
    },
