    {
      "id": "E:note:row673718:1",
      "kind": "note_sentence",
      "display": "60 y/o M  w/ an extensive PMH including R Hip hemiarthroplasty,    diverticuliti",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s1",
      "text": "60 y/o M  w/ an extensive PMH including R Hip hemiarthroplasty,    diverticulitis, Renal transplant 01, who presented to ED complaining    of worsening SOB x 2 days."
    },
    {
      "id": "E:note:row673718:2",
      "kind": "note_sentence",
      "display": "In the ED his vitals were significant for a    NBP 193/113, and profound insp/ex",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s2",
      "text": "In the ED his vitals were significant for a    NBP 193/113, and profound insp/exp wheezes, he received several    abluterol/atrovent nebs, and was transferred to the M/SICU for further    management of a COPD exacerbation and hypertension."
    },
    {
      "id": "E:note:row673718:3",
      "kind": "note_sentence",
      "display": "Hypertension, benign    Assessment:    SBP 110 s to 170 s with HR 110 s to 120 s",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s3",
      "text": "Hypertension, benign    Assessment:    SBP 110 s to 170 s with HR 110 s to 120 s throughout shift."
    },
    {
      "id": "E:note:row673718:4",
      "kind": "note_sentence",
      "display": "Pt. remains    on fentanyl 100mcg/kg and propofol 90mcg/kg for sedation/comfort.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s4",
      "text": "Pt. remains    on fentanyl 100mcg/kg and propofol 90mcg/kg for sedation/comfort."
    },
    {
      "id": "E:note:row673718:5",
      "kind": "note_sentence",
      "display": "Action:    Pt. given IV hydralazine q6hr along with drips as noted above.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s5",
      "text": "Action:    Pt. given IV hydralazine q6hr along with drips as noted above."
    },
    {
      "id": "E:note:row673718:6",
      "kind": "note_sentence",
      "display": "Pt.    bolused with 100mcg of fentanyl prior to nsg. care.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s6",
      "text": "Pt.    bolused with 100mcg of fentanyl prior to nsg. care."
    },
    {
      "id": "E:note:row673718:7",
      "kind": "note_sentence",
      "display": "Response:    SBP remained labile throughout shift ranging from 110 s to 170    R",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s7",
      "text": "Response:    SBP remained labile throughout shift ranging from 110 s to 170    Remained tachycardic throughout shift."
    },
    {
      "id": "E:note:row673718:8",
      "kind": "note_sentence",
      "display": "Plan:    Continue to monitor patient hemodynamic status closely.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s8",
      "text": "Plan:    Continue to monitor patient hemodynamic status closely."
    },
    {
      "id": "E:note:row673718:9",
      "kind": "note_sentence",
      "display": "Continue with    propofol, fentanyl and hydralazine as ordered.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s9",
      "text": "Continue with    propofol, fentanyl and hydralazine as ordered."
    },
    {
      "id": "E:note:row673718:10",
      "kind": "note_sentence",
      "display": "If pt. remains    hypertensive, may need to increase hydralazine dose.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s10",
      "text": "If pt. remains    hypertensive, may need to increase hydralazine dose."
    },
    {
      "id": "E:note:row673718:11",
      "kind": "note_sentence",
      "display": "Chronic obstructive pulmonary disease (COPD, Bronchitis, Emphysema)    with Acut",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row673718#s11",
      "text": "Chronic obstructive pulmonary disease (COPD, Bronchitis, Emphysema)    with Acute Exacerbation    Assessment:    Pt. remains intubated and vented on PSV 40% 15/5 with sats at high 90    RR in 10 s."
    },
    {
      "id": "E:note:row673718:12",
      "kind": "note_sentence",
      "display": "Breath sounds diminished throughout.",
      "code": null,
      "value": null,
      "unit": null,
