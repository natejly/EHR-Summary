    {
      "id": "E:note:row447958:1",
      "kind": "note_sentence",
      "display": "This is a 62 yo M with pmh of kidney transplant in [**Country 297**] 3 years ago",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row447958#s1",
      "text": "This is a 62 yo M with pmh of kidney transplant in [**Country 297**] 3 years ago    who has been in the US for the last 4 months and is experiencing    intermittent fevers to 102 without source for the last week."
    },
    {
      "id": "E:note:row447958:2",
      "kind": "note_sentence",
      "display": "He was at    [**Hospital1 1200**] for these fevers for the last 3 days without a",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row447958#s2",
      "text": "He was at    [**Hospital1 1200**] for these fevers for the last 3 days without a diagnosis and    has continued to experience fevers at home."
    },
    {
      "id": "E:note:row447958:3",
      "kind": "note_sentence",
      "display": "There he was given Zosyn    without improvement.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row447958#s3",
      "text": "There he was given Zosyn    without improvement."
    },
    {
      "id": "E:note:row447958:4",
      "kind": "note_sentence",
      "display": "He therefore presented to the ED for further    evaluation.    .",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row447958#s4",
      "text": "He therefore presented to the ED for further    evaluation.    ."
    },
    {
      "id": "E:note:row447958:5",
      "kind": "note_sentence",
      "display": "In the ED, initial VS were 99.2 101 18 136/83 97% on RA.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row447958#s5",
      "text": "In the ED, initial VS were 99.2 101 18 136/83 97% on RA."
    },
    {
