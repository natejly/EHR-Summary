      "id": "E:note:row701538:3",
      "kind": "note_sentence",
      "display": "He also has L leg pain and    erythema.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row701538#s3",
      "text": "He also has L leg pain and    erythema."
