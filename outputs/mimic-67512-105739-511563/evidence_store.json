      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s4",
      "text": "He also notes a 40 lbs weight gain that he reports over the last    few weeks (from 330 to 360)."
    },
    {
      "id": "E:note:row511563:5",
      "kind": "note_sentence",
      "display": "Worsening leg edema, ascites.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s5",
      "text": "Worsening leg edema, ascites."
    },
    {
