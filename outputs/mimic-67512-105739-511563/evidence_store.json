      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s12",
      "text": "Pressure dropped to 80s, then responded to 90s after    given some fluids (500cc NS)."
    },
    {
      "id": "E:note:row511563:13",
      "kind": "note_sentence",
      "display": "Held lasix (takes 160 per day?).",
      "code": null,
      "value": null,
