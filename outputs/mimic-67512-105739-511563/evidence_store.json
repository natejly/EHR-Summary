      "kind": "note_sentence",
      "display": "No recent    fevers, no abdominal pain.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s6",
      "text": "No recent    fevers, no abdominal pain."
    },
    {
      "id": "E:note:row511563:7",
      "kind": "note_sentence",
      "display": "C/o diarrhea x 2 days and some chills    recently.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s7",
      "text": "C/o diarrhea x 2 days and some chills    recently."
    },
    {
      "id": "E:note:row511563:8",
      "kind": "note_sentence",
      "display": "He describes chest pain that started on the right side of his    chest one day p",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s8",
      "text": "He describes chest pain that started on the right side of his    chest one day prior to admission."
    },
    {
      "id": "E:note:row511563:9",
      "kind": "note_sentence",
      "display": "It is pleuritic in nature and ranges    from [**2184-3-15**].",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s9",
      "text": "It is pleuritic in nature and ranges    from [**2184-3-15**]."
    },
    {
      "id": "E:note:row511563:10",
      "kind": "note_sentence",
      "display": "In the ED, vitals were 97.8 89 123/64 24 96 on RA.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row511563#s10",
      "text": "In the ED, vitals were 97.8 89 123/64 24 96 on RA."
    },
    {
