    {
      "id": "E:note:row640463:1",
      "kind": "note_sentence",
      "display": "This is a 68 year-old woman POD 5 s/p ventral hernia repair.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s1",
      "text": "This is a 68 year-old woman POD 5 s/p ventral hernia repair."
    },
    {
      "id": "E:note:row640463:2",
      "kind": "note_sentence",
      "display": "Post-operative course complicated by tachycardia, persistent fevers,    and alte",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s2",
      "text": "Post-operative course complicated by tachycardia, persistent fevers,    and altered mental status."
    },
    {
      "id": "E:note:row640463:3",
      "kind": "note_sentence",
      "display": "Recent surgery at OSH for SBO complicated by    wound infection and abscess as w",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s3",
      "text": "Recent surgery at OSH for SBO complicated by    wound infection and abscess as well as ventral hernia, which was the    subject of this current surgery."
    },
    {
      "id": "E:note:row640463:4",
      "kind": "note_sentence",
      "display": "Central line inserted on [**9-9**],    peripheral IV for IV contrast was tried b",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s4",
      "text": "Central line inserted on [**9-9**],    peripheral IV for IV contrast was tried by IV nurse and the team under    ultrasound guidance, to no avail."
    },
    {
      "id": "E:note:row640463:5",
      "kind": "note_sentence",
      "display": "CT was then done with only with oral    contrast.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s5",
      "text": "CT was then done with only with oral    contrast."
    },
    {
      "id": "E:note:row640463:6",
      "kind": "note_sentence",
      "display": "CT scan of abdomen and sinuses done on [**9-20**], continued on    Vancomycin an",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s6",
      "text": "CT scan of abdomen and sinuses done on [**9-20**], continued on    Vancomycin and Zosyn."
    },
    {
      "id": "E:note:row640463:7",
      "kind": "note_sentence",
      "display": "The CT scan of abdomen of abdomen showed a    hematoma.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s7",
      "text": "The CT scan of abdomen of abdomen showed a    hematoma."
    },
    {
      "id": "E:note:row640463:8",
      "kind": "note_sentence",
      "display": "Pt needs to be sent to OR for evacuation of hematoma.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row640463#s8",
      "text": "Pt needs to be sent to OR for evacuation of hematoma."
    },
    {
      "id": "E:note:row640463:9",
      "kind": "note_sentence",
