    {
      "id": "E:note:row629067:1",
      "kind": "note_sentence",
      "display": "63 year old woman with lupus, obesity, prior thyroid lymphoma with    resultant ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row629067#s1",
      "text": "63 year old woman with lupus, obesity, prior thyroid lymphoma with    resultant hypothyroidism who was found down at her home- noted to be    bradycardic and hypotensive by EMS, unable to transcutaneously pace in    the field."
    },
    {
      "id": "E:note:row629067:2",
      "kind": "note_sentence",
      "display": "In the ED at [**Hospital3 3191**] Hospital she continued to be    bradycardic, i",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row629067#s2",
      "text": "In the ED at [**Hospital3 3191**] Hospital she continued to be    bradycardic, in complete heart block by report, she was coded for    bradycardia HR 20s rec'd epi/ atropine/ glucagon/ etc. A temporary    transvenous pacing wire was placed."
    },
    {
      "id": "E:note:row629067:3",
      "kind": "note_sentence",
      "display": "She was intubated, started on    dopamine and propofol and transferred here for ",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row629067#s3",
      "text": "She was intubated, started on    dopamine and propofol and transferred here for further care."
    },
    {
      "id": "E:note:row629067:4",
      "kind": "note_sentence",
      "display": "She is in    a hard collar r/t unwitnessed fall, CT head at OSH pnd.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row629067#s4",
      "text": "She is in    a hard collar r/t unwitnessed fall, CT head at OSH pnd."
    },
