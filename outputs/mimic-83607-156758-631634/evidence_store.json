    },
    {
      "id": "E:note:row631634:2",
      "kind": "note_sentence",
      "display": "Hepatitis B with autoimmune    cholangiopathy, ESRD, Diabetes, HTN, CVA with lef",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s2",
      "text": "Hepatitis B with autoimmune    cholangiopathy, ESRD, Diabetes, HTN, CVA with left sided weakness most    notable in Leg."
    },
    {
      "id": "E:note:row631634:3",
      "kind": "note_sentence",
      "display": "Recent long complicated hospitalization [**Date range (1) 11787**] for    compli",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s3",
      "text": "Recent long complicated hospitalization [**Date range (1) 11787**] for    complications of PEG placement on [**1-16**] with abdominal wall abscess s/p    ex lap, closure of gastrostomy and peg removal, I&D abd wall abscess    X3/necrotizing fasciitis with wound vac."
    },
    {
      "id": "E:note:row631634:4",
      "kind": "note_sentence",
      "display": "Pt was at rehab after    complicated hospital coarse and started treatment for p",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s4",
      "text": "Pt was at rehab after    complicated hospital coarse and started treatment for positive CDIFF on    3/31pt was subsequently sent back to [**Hospital1 1**] on [**4-6**] for increased WBC    with hypotension and lethargy."
    },
    {
      "id": "E:note:row631634:5",
      "kind": "note_sentence",
      "display": "Pt was admitted on [**4-6**] to MICU was    volume resuscitated with good effect",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s5",
      "text": "Pt was admitted on [**4-6**] to MICU was    volume resuscitated with good effect on SBP."
    },
    {
      "id": "E:note:row631634:6",
      "kind": "note_sentence",
      "display": "Pt also had a    paracentesis done without evidence of SBP.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s6",
      "text": "Pt also had a    paracentesis done without evidence of SBP."
    },
    {
      "id": "E:note:row631634:7",
      "kind": "note_sentence",
      "display": "Leni s done which showed no    clot but upper extremity US showing old RIJ clot,",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s7",
      "text": "Leni s done which showed no    clot but upper extremity US showing old RIJ clot, L brachial clot and    RUQ ultrasound showing new portal vein clot."
    },
    {
      "id": "E:note:row631634:8",
      "kind": "note_sentence",
      "display": "Pt stabilized and then    trnf to floor on [**4-8**].",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s8",
      "text": "Pt stabilized and then    trnf to floor on [**4-8**]."
    },
    {
      "id": "E:note:row631634:9",
      "kind": "note_sentence",
      "display": "On floor pt with persistent fevers and profuse    diarrhea.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s9",
      "text": "On floor pt with persistent fevers and profuse    diarrhea."
    },
    {
      "id": "E:note:row631634:10",
      "kind": "note_sentence",
      "display": "ABX restarted on [**4-11**] [**2-2**] to fever 103.",
      "code": null,
      "value": null,
      "unit": null,
      "effective": null,
      "source_ref": "note:row631634#s10",
      "text": "ABX restarted on [**4-11**] [**2-2**] to fever 103."
    },
